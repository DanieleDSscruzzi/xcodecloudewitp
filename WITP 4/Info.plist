<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>it</string>

    <key>CFBundleDisplayName</key>
    <string>WITP</string>

    <key>CFBundleName</key>
    <string>WITP</string>

    <key>CFBundleIdentifier</key>
    <string>com.danielescruzzi.witp</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>MinimumOSVersion</key>
    <string>17.0</string>

    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Asset catalog icon name (richiesto da iOS 11+) -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>

    <!-- Posizione -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>WITP usa la tua posizione per trovare parcheggi vicino a te con la pipeline WDSL+.</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>WITP può monitorare la posizione in background per avvisarti quando stai per scadere la sosta.</string>

    <!-- Notifiche -->
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>fetch</string>
        <string>processing</string>
    </array>

    <!-- Mappe -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>maps</string>
        <string>comgooglemaps</string>
    </array>

    <!-- Launch & UI -->
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>LaunchBackground</string>
    </dict>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <key>UIUserInterfaceStyle</key>
    <string>Dark</string>

    <!-- Apple Silicon required features (performance hints) -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
        <string>metal</string>
        <string>location-services</string>
    </array>
</dict>
</plist>
